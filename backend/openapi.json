openapi: 3.0.3
info:
  title: EraNux API
  version: 1.0.0
  description: Backend API
paths:
  /api/bookings/:
    get:
      operationId: bookings_list
      description: Booking API
      tags:
      - bookings
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/BookingDetail'
          description: ''
